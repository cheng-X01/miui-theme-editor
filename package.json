{
  "name": "miui-theme-editor",
  "version": "0.1.0",
  "description": "全功能小米手机主题编辑生成器 - AI增强版",
  "author": "AI Dev Team",
  "license": "MIT",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "electron": "^30.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0",
    "antd": "^5.17.0",
    "@monaco-editor/react": "^4.6.0",
    "lottie-react": "^2.4.0",
    "react-dnd": "^16.0.0",
    "react-dnd-html5-backend": "^16.0.0",
    "react-colorful": "^5.6.0",
    "fabric": "^5.3.0",
    "jszip": "^3.10.0",
    "fast-xml-parser": "^4.3.0",
    "sharp": "^0.33.0",
    "adbkit": "^2.11.0",
    "uuid": "^9.0.0",
    "lodash-es": "^4.17.0",
    "openai": "^4.47.0",
    "ollama": "^0.5.0",
    "axios": "^1.7.0",
    "event-source-polyfill": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "@types/lodash-es": "^4.17.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron-builder": "^24.13.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^1.6.0",
    "@testing-library/react": "^15.0.0",
    "@vitest/ui": "^1.6.0"
  },
  "build": {
    "appId": "com.miui.theme-editor",
    "productName": "MIUI Theme Editor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
